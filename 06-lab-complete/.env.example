# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=Lab 11 Guardrails Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# LAB 11: GUARDRAILS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Enable/disable guardrails
ENABLE_INPUT_GUARDRAILS=true
ENABLE_OUTPUT_GUARDRAILS=true
ENABLE_INJECTION_DETECTION=true
ENABLE_TOPIC_FILTER=true

# HITL Configuration
ENABLE_HITL=true
CONFIDENCE_THRESHOLD_HIGH=0.8
CONFIDENCE_THRESHOLD_LOW=0.3
